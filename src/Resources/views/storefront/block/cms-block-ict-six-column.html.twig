{% block block_ict_six_column %}
    {% set slots = [
        block.slots.getSlot('left'),
        block.slots.getSlot('leftCenter'),
        block.slots.getSlot('centerLeft'),
        block.slots.getSlot('centerRight'),
        block.slots.getSlot('rightCenter'),
        block.slots.getSlot('right')
    ] %}

    {% for slot in slots %}
        {% if slot %}
            <div class="col-lg-2 col-md-6 col-12 ict-six-column-layout__col" data-cms-element-id="{{ slot.id }}">
                <div class="ict-six-column-layout__card-slot">
                    {% sw_include '@Storefront/storefront/element/cms-element-' ~ slot.type ~ '.html.twig' ignore missing with { element: slot } %}
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endblock %}
