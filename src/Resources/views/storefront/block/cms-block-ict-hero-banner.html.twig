{% block block_ict_hero_banner %}
    {% set element = block.slots.getSlot('content') %}

    <div class="col-12 ict-hero-banner-col" data-cms-element-id="{{ element.id }}">
        {% block block_ict_hero_banner_content %}
            {% sw_include '@Storefront/storefront/element/cms-element-' ~ element.type ~ '.html.twig' ignore missing %}
        {% endblock %}
    </div>
{% endblock %}
