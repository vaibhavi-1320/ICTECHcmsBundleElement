{% block block_ict_platform_support %}
    {% set element = block.slots.getSlot('platformSupport') %}

    {% if element %}
        <div class="cms-block-ict-platform-support">
            <div data-cms-element-id="{{ element.id }}">
                {% sw_include '@Storefront/storefront/element/cms-element-' ~ element.type ~ '.html.twig' ignore missing with { element: element } %}
            </div>
        </div>
    {% endif %}
{% endblock %}
