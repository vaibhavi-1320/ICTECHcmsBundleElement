{% block element_ict_six_column %}
    {% set media = element.data.media ?? null %}
    {% set eyebrow = element.config.eyebrow.value ?? '' %}
    {% set title = element.config.title.value ?? '' %}
    {% set text = element.config.text.value ?? '' %}
    {% set linkText = element.config.linkText.value ?? '' %}
    {% set url = element.config.url.value ?? '' %}
    {% set newTab = element.config.newTab.value ?? false %}

    <div class="cms-element-ict-six-column ict-six-column-card">
        <div class="ict-six-column-card__media">
            {% if media %}
                <img
                    src="{{ media.url }}"
                    alt="{{ media.translated.alt|default(title) }}"
                >
            {% else %}
                <div class="ict-six-column-card__media-placeholder">
                    {{ title }}
                </div>
            {% endif %}
        </div>

        <div class="ict-six-column-card__content">
            {% if eyebrow %}
                <p class="ict-six-column-card__eyebrow">
                    {{ eyebrow }}
                </p>
            {% endif %}

            {% if title %}
                <h3 class="ict-six-column-card__title">
                    {{ title }}
                </h3>
            {% endif %}

            {% if text %}
                <p class="ict-six-column-card__text">
                    {{ text }}
                </p>
            {% endif %}

            {% if linkText %}
                {% if url %}
                    <a
                        class="ict-six-column-card__link"
                        href="{{ url }}"
                        {% if newTab %}target="_blank" rel="noopener noreferrer"{% endif %}
                    >
                        {{ linkText }}
                    </a>
                {% else %}
                    <span class="ict-six-column-card__link">
                        {{ linkText }}
                    </span>
                {% endif %}
            {% endif %}
        </div>
    </div>
{% endblock %}
