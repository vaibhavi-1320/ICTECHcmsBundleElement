{% block element_ict_platform_support %}
{% set config = element.config %}
{% set data = element.data %}
<div class="cms-element-ict-platform-support" style="
        {% if config.backgroundType.value == 'color' %}
            background-color: {{ config.platformBlockBackground.value }};
        {% elseif config.backgroundType.value == 'image' and data.backgroundImage %}
            background-image: url('{{ data.backgroundImage.url }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: {{ config.backgroundImageMinHeight.value|default('400px') }};
        {% elseif config.backgroundType.value == 'gradient' %}
            background: linear-gradient({{ config.gradientDirection.value }}, {{ config.gradientColor1.value }}, {{ config.gradientColor2.value }});
        {% endif %}
        padding: 48px;
        border-radius: {{ config.platformBlockBorderRadius.value ?? 0 }}px;
        position: relative;
        overflow: hidden;
    "
    {% if config.backgroundType.value == 'gradient' and config.hoverGradientColor1.value and config.hoverGradientColor2.value %}
        onmouseover="this.style.background='linear-gradient({{ config.gradientDirection.value }}, {{ config.hoverGradientColor1.value }}, {{ config.hoverGradientColor2.value }})'"
        onmouseout="this.style.background='linear-gradient({{ config.gradientDirection.value }}, {{ config.gradientColor1.value }}, {{ config.gradientColor2.value }})'"
    {% endif %}>
    {% if config.backgroundType.value == 'video' %}
    {% if config.backgroundVideoUploadType.value == 'url' and config.backgroundVideoUploadUrl.value %}
    {% set videoUrl = config.backgroundVideoUploadUrl.value %}
    {% if 'youtube.com' in videoUrl or 'youtu.be' in videoUrl %}
    {% set videoId = videoUrl|replace({'https://www.youtube.com/watch?v=': '', 'https://youtu.be/': '', '&':
    '?'})|split('?')[0] %}
    <iframe class="background-video-iframe"
        src="https://www.youtube.com/embed/{{ videoId }}?autoplay=1&mute=1&loop=1&playlist={{ videoId }}&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1"
        allow="autoplay; encrypted-media" allowfullscreen>
    </iframe>
    {% elseif 'vimeo.com' in videoUrl %}
    {% set videoId = videoUrl|split('/')|last %}
    <iframe class="background-video-iframe" src="https://player.vimeo.com/video/{{ videoId }}?autoplay=1&muted=1&loop=1&background=1&controls=0"
        allow="autoplay; fullscreen" allowfullscreen>
    </iframe>
    {% else %}
    <video class="background-video" autoplay muted loop playsinline>
        <source src="{{ videoUrl }}" type="video/mp4">
        <source src="{{ videoUrl }}" type="video/webm">
        <source src="{{ videoUrl }}" type="video/ogg">
    </video>
    {% endif %}
    {% elseif config.backgroundVideoUploadType.value == 'file' and data.backgroundVideo %}
    <video class="background-video" autoplay muted loop playsinline>
        <source src="{{ data.backgroundVideo.url }}" type="video/mp4">
    </video>
    {% endif %}
    {% endif %}

    {% if config.platformBlockTitle.value %}
    <h2 class="platform-block-title" style="
                font-size: {{ config.platformTitleSize.value }}px;
                line-height: {{ config.platformTitleLineHeight.value ?? 28 }}px;
                font-weight: 700;
                color: {{ config.platformTitleColor.value }};
                text-align: {{ config.platformTitleAlignment.value }};
                margin-bottom: 2rem;
                position: relative;
                z-index: 2;
            ">
        {{ config.platformBlockTitle.value }}
    </h2>
    {% endif %}

    <div class="platform-grid" style="
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 32px;
            justify-items: {{ config.platformAlignment.value }};
            position: relative;
            z-index: 2;
        ">

        {% for platform in data.platformItems ?? config.platformItems.value %}
        {% set platformElement = platform %}
        {% if platformElement.platformLinkUrl %}
        <a href="{{ platformElement.platformLinkUrl }}" target="{{ platformElement.platformLinkTarget }}"
            class="platform-item-link">
            {% endif %}

            <div class="platform-item" style="
                    {% if platformElement.textAlignment == 'right' %}
                        flex-direction: row;
                        align-items: center;
                    {% elseif platformElement.textAlignment == 'left' %}
                        flex-direction: row-reverse;
                        align-items: center;
                    {% elseif platformElement.textAlignment == 'center-top' %}
                        flex-direction: column-reverse;
                        align-items: center;
                    {% else %}
                        flex-direction: column;
                        align-items: center;
                    {% endif %}
                    gap: 10px;
                    cursor: {{ platformElement.platformLinkUrl ? platformElement.platformLinkUrl : 'default' }};
                ">
                <div class="platform-icon" style="
                        width: {{ platformElement.iconSizePx ?? '48' }}px;
                        height: {{ platformElement.iconSizePx ?? '48' }}px;
                        {% if platformElement.iconBackgroundType == 'gradient' %}
                            background: linear-gradient({{ platformElement.iconGradientDirection }}, {{ platformElement.iconGradientColor1 }}, {{ platformElement.iconGradientColor2 }});
                        {% elseif platformElement.iconBackgroundType == 'solid' %}
                            background-color: {{ platformElement.iconBackgroundColor }};
                        {% else %}
                            background: transparent;
                        {% endif %}
                        {% if platformElement.iconBackgroundShape == 'circle' %}
                            border-radius: 50%;
                        {% elseif platformElement.iconBackgroundShape == 'rounded' %}
                            border-radius: 12px;
                        {% elseif platformElement.iconBackgroundShape == 'square' %}
                            border-radius: 4px;
                        {% else %}
                            border-radius: 8px;
                        {% endif %}
                        {% if platformElement.platformIconShadow %}
                            {% set shadowColor = platformElement.platformShadowColor ?? '#808080' %}
                            box-shadow: 0 4px 12px {{ shadowColor }}26;
                        {% endif %}
                        transition: all 0.3s ease;
                    ">
                    {% if platformElement.iconMedia %}
                    <img class="platform-icon-img" src="{{ platformElement.iconMedia.url }}" alt="{{ platformElement.platformLabel }}" style="
                        width: {{ (platformElement.iconSizePx ?? '48')|number_format * 0.7 }}px;
                        height: {{ (platformElement.iconSizePx ?? '48')|number_format * 0.7 }}px;
                        object-fit: contain;
                    ">
                    {% elseif data.platformIcons and data.platformIcons[loop.index0] %}
                    <img class="platform-icon-img" src="{{ data.platformIcons[loop.index0].url }}" alt="{{ platformElement.platformLabel }}" style="
                        width: {{ (platformElement.iconSizePx ?? '48')|number_format * 0.7 }}px;
                        height: {{ (platformElement.iconSizePx ?? '48')|number_format * 0.7 }}px;
                        object-fit: contain;
                    ">
                    {% else %}
                    <div class="platform-icon-placeholder" style="
                                    border: 2px solid {{ platformElement.iconColor ?? '#ffffff' }};
                                    width: 16px;
                                    height: 12px;
                                    border-radius: 2px;
                                "></div>
                    {% endif %}
                </div>

                {% if platformElement.platformLabel %}
                <span class="platform-label" style="
                            font-size: {{ platformElement.platformLabelSizePx ?? '16' }}px;
                            font-weight: {{ platformElement.platformLabelWeight ?? '400' }};
                            color: {{ platformElement.platformLabelColor }};
                            {% if platformElement.textAlignment == 'right' or platformElement.textAlignment == 'left' %}
                                text-align: left;
                            {% else %}
                                text-align: center;
                            {% endif %}
                            transition: all 0.3s ease;
                        "
                        {% if platformElement.textHoverUnderline or platformElement.textHoverColorChange %}
                            onmouseover="
                                {% if platformElement.textHoverUnderline %}this.style.textDecoration='underline';{% endif %}
                                {% if platformElement.textHoverColorChange %}this.style.color='{{ platformElement.textHoverColor }}';{% endif %}
                            "
                            onmouseout="
                                {% if platformElement.textHoverUnderline %}this.style.textDecoration='none';{% endif %}
                                {% if platformElement.textHoverColorChange %}this.style.color='{{ platformElement.platformLabelColor }}';{% endif %}
                            "
                        {% endif %}>
                    {{ platformElement.platformLabel }}
                </span>
                {% endif %}
            </div>

            {% if platformElement.platformLinkUrl %}
        </a>
        {% endif %}
        {% endfor %}

    </div>

</div>

<style>
    @media (max-width: 767px) {
        .cms-block-ict-platform-support .platform-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }

    @media (min-width: 768px) and (max-width: 1024px) {
        .cms-block-ict-platform-support .platform-grid {
            grid-template-columns: repeat(4, 1fr) !important;
        }
    }

    .platform-item-link:hover {
        text-decoration: none;
        cursor: default;
    }
</style>
{% endblock %}
