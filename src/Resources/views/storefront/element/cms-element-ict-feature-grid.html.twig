{% block element_ict_feature_grid %}
    {% set config   = element.config %}
    {% set slotData = element.data %}
    {% set cards    = config.cards.value ?? [] %}
    {% set columns  = config.numberOfColumns.value ?? 3 %}
    {% set spacing  = config.cardSpacing.value ?? 20 %}

    <div class="cms-element-ict-feature-grid">
        <div class="ifg-grid" style="grid-template-columns: repeat({{ columns }}, minmax(0, 1fr)); gap: {{ spacing }}px;">

            {% for card in cards %}
                {% set cardIndex      = loop.index0 %}
                {% set iconMedia      = slotData.iconImages[cardIndex] ?? null %}
                {% set cardImageMedia = slotData.cardImages[cardIndex] ?? null %}
                {% set cardVideoMedia = slotData.cardVideos[cardIndex] ?? null %}
                {% set accentColor    = card.cardAccentColor ?? '#6366f1' %}
                {% set bgColor        = card.cardBackgroundColor ?? '#ffffff' %}

                {% set mediaHeightRaw = (card.mediaHeight ?? '200') ~ '' %}
                {% set mediaHeightCss = mediaHeightRaw matches '/^[0-9]+(\\.[0-9]+)?$/' ? mediaHeightRaw ~ 'px' : mediaHeightRaw %}
                {% set objectFit      = (card.mediaDisplayMode ?? 'crop') == 'crop' ? 'cover' : 'contain' %}

                {% set activeButton = null %}
                {% if card.buttons is defined and card.buttons is iterable %}
                    {% for btn in card.buttons %}
                        {% if activeButton is null and (btn.show is not defined or btn.show) %}
                            {% set activeButton = btn %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <div class="ifg-card" style="--ifg-accent: {{ accentColor }}; background-color: {{ bgColor }};">
                    <div class="ifg-card__accent-bar"></div>

                    <div class="ifg-card__media" style="height: {{ mediaHeightCss }};">
                        {% if cardImageMedia %}
                            <img
                                class="ifg-card__media-img"
                                src="{{ cardImageMedia.url }}"
                                alt="{{ card.headline ?? 'Media' }}"
                                style="object-fit: {{ objectFit }};"
                            >
                        {% elseif card.cardBackgroundVideoUploadType == 'url' and card.cardBackgroundVideoUploadUrl %}
                            {% set ytUrl = card.cardBackgroundVideoUploadUrl %}
                            {% set ytId = '' %}
                            {% if 'v=' in ytUrl %}
                                {% set ytId = ytUrl|split('v=')[1]|split('&')[0]|split('?')[0]|split('#')[0] %}
                            {% elseif 'youtu.be/' in ytUrl %}
                                {% set ytId = ytUrl|split('youtu.be/')[1]|split('?')[0]|split('&')[0]|split('#')[0] %}
                            {% elseif '/live/' in ytUrl %}
                                {% set ytId = ytUrl|split('/live/')[1]|split('?')[0]|split('&')[0]|split('#')[0] %}
                            {% elseif '/shorts/' in ytUrl %}
                                {% set ytId = ytUrl|split('/shorts/')[1]|split('?')[0]|split('&')[0]|split('#')[0] %}
                            {% elseif '/embed/' in ytUrl %}
                                {% set ytId = ytUrl|split('/embed/')[1]|split('?')[0]|split('&')[0]|split('#')[0] %}
                            {% endif %}
                            {% if ytId %}
                            <iframe
                                class="ifg-card__media-iframe"
                                src="https://www.youtube.com/embed/{{ ytId }}?autoplay=1&mute=1&loop=1&playlist={{ ytId }}&controls=0&rel=0"
                                frameborder="0"
                                allowfullscreen>
                            </iframe>
                            {% endif %}
                        {% elseif card.cardBackgroundVideoUploadType == 'file' and cardVideoMedia %}
                            <video autoplay muted loop class="ifg-card__media-video" style="object-fit: {{ objectFit }};">
                                <source src="{{ cardVideoMedia.url }}" type="video/mp4">
                            </video>
                        {% else %}
                            <div class="ifg-card__media-placeholder"></div>
                        {% endif %}
                    </div>

                    <div class="ifg-card__body">
                        <div class="ifg-card__icon-wrap" style="color: {{ card.iconColor ?? '#6366f1' }};">
                            {% if iconMedia %}
                                {% if '.svg' in iconMedia.url %}
                                    <span class="ifg-card__icon-mask" style="
                                        background-color: {{ card.iconColor ?? '#6366f1' }};
                                        -webkit-mask-image: url('{{ iconMedia.url }}');
                                        mask-image: url('{{ iconMedia.url }}');
                                    "></span>
                                {% else %}
                                    <img src="{{ iconMedia.url }}" alt="Icon" class="ifg-card__icon-img">
                                {% endif %}
                            {% else %}
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                                </svg>
                            {% endif %}
                        </div>

                        <h3 class="ifg-card__headline" style="color: {{ card.headlineColor ?? '#1e293b' }};">
                            {{ card.headline }}
                        </h3>

                        {% if (card.subheadline ?? '')|trim %}
                            <p class="ifg-card__subheadline" style="color: {{ card.subheadlineColor ?? '#64748b' }};">
                                {{ card.subheadline }}
                            </p>
                        {% endif %}

                        <div class="ifg-card__body-text" style="color: {{ card.bodyTextColor ?? '#64748b' }};">
                            {{ card.bodyText|raw }}
                        </div>

                        {% if activeButton %}
                            <div class="ifg-card__footer">
                                <a
                                    href="{{ activeButton.buttonUrl ?? '#' }}"
                                    target="{{ activeButton.buttonTarget ?? '_self' }}"
                                    class="ifg-card__btn"
                                    style="color: {{ activeButton.buttonTextColor ?? '#ffffff' }};"
                                >
                                    {{ activeButton.buttonText ?? 'Learn More' }}
                                    <svg class="ifg-card__btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M5 12h14M12 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}

        </div>
    </div>
{% endblock %}
