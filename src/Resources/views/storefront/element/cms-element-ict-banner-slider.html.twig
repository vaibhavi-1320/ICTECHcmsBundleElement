{% block element_ict_banner_slider %}
    {% set sliderItems = element.config.sliderItems.value ?? [] %}
    {% set displayMode = element.config.displayMode.value ?? 'contain' %}
    {% set autoTransition = element.config.autoTransition.value ?? false %}
    {% set navigationDots = element.config.navigationDots.value ?? 'none' %}
    {% set navigationArrows = element.config.navigationArrows.value ?? 'outside' %}
    {% set hasMultipleSlides = sliderItems|length > 1 %}
    {% set baseSliderOptions = {
        slider: {
            controls: navigationArrows != 'none' and hasMultipleSlides,
            nav: navigationDots != 'none' and hasMultipleSlides,
            navPosition: 'bottom',
            items: 1,
            mode: 'carousel',
            mouseDrag: hasMultipleSlides,
            touchDrag: hasMultipleSlides,
            autoplay: autoTransition and hasMultipleSlides,
            autoplayButtonOutput: false,
            autoplayHoverPause: true,
            autoplayTimeout: 5000,
            speed: 400,
            edgePadding: 0,
            gutter: 0,
            loop: hasMultipleSlides,
            rewind: false,
            ariaLive: autoTransition and hasMultipleSlides ? false : true,
            autoHeight: false,
        }
    } %}

    {% if sliderItems|length > 0 %}
        <div class="cms-element-ict-banner-slider">
            <div
                class="base-slider image-slider{% if navigationArrows == 'outside' %} has-nav-outside{% endif %}{% if navigationDots == 'outside' %} has-dots-outside{% endif %}"
                data-base-slider="true"
                data-base-slider-options="{{ baseSliderOptions|json_encode|e('html_attr') }}"
                role="region"
                aria-label="Banner slider"
                tabindex="0"
            >
                <div class="image-slider-container" data-base-slider-container="true">
                    {% for item in sliderItems %}
                        <div class="image-slider-item-container">
                            <div class="image-slider-item{% if not loop.first %} is-not-first{% endif %} is-{{ displayMode }}">
                                <div class="ict-banner-slider__image-wrapper">
                                    <img
                                        src="{{ item.mediaUrl }}"
                                        class="ict-banner-slider__image img-fluid image-slider-image"
                                        alt="{{ item.mainTitle }}"
                                        loading="lazy"
                                    >
                                </div>

                                <div class="ict-banner-slider__content-wrapper">
                                    <div class="container">
                                        <div class="ict-banner-slider__content">
                                            {% if item.mainTitle %}
                                                <h1 class="ict-banner-slider__main-title" {% if item.mainTitleColor %}style="color: {{ item.mainTitleColor|e('html_attr') }}"{% endif %}>{{ item.mainTitle }}</h1>
                                            {% endif %}

                                            {% if item.subTitle %}
                                                <h2 class="ict-banner-slider__sub-title" {% if item.subTitleColor %}style="color: {{ item.subTitleColor|e('html_attr') }}"{% endif %}>{{ item.subTitle }}</h2>
                                            {% endif %}

                                            {% if item.description %}
                                                <p class="ict-banner-slider__description" {% if item.descriptionColor %}style="color: {{ item.descriptionColor|e('html_attr') }}"{% endif %}>{{ item.description }}</p>
                                            {% endif %}

                                            <div class="ict-banner-slider__actions">
                                                {% if item.callButtonText and item.callButtonNumber %}
                                                    {% set btnBg = item.buttonColor ?? '#f15a24' %}
                                                    {% set btnTxt = item.buttonTextColor ?? '#ffffff' %}
                                                    <a href="tel:{{ item.callButtonNumber }}" class="btn ict-banner-slider__btn ict-banner-slider__btn--call" style="background-color: {{ btnBg|e('html_attr') }}; border-color: {{ btnBg|e('html_attr') }}; color: {{ btnTxt|e('html_attr') }}">
                                                        <span class="ict-banner-slider__btn-icon">
                                                            {% sw_icon 'phone' %}
                                                        </span>
                                                        {{ item.callButtonText }}
                                                    </a>
                                                {% endif %}

                                                {% if item.emailButtonText and item.emailButtonAddress %}
                                                    {% set btnBg = item.buttonColor ?? '#f15a24' %}
                                                    {% set btnTxt = item.buttonTextColor ?? '#ffffff' %}
                                                    <a href="mailto:{{ item.emailButtonAddress }}" class="btn ict-banner-slider__btn ict-banner-slider__btn--email" style="background-color: {{ btnBg|e('html_attr') }}; border-color: {{ btnBg|e('html_attr') }}; color: {{ btnTxt|e('html_attr') }}">
                                                        <span class="ict-banner-slider__btn-icon">
                                                            {% sw_icon 'envelope' %}
                                                        </span>
                                                        {{ item.emailButtonText }}
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {% if navigationArrows != 'none' and hasMultipleSlides %}
                    <div class="image-slider-controls-container">
                        <div class="base-slider-controls" data-base-slider-controls="true">
                            <button
                                class="base-slider-controls-prev image-slider-controls-prev{% if navigationArrows == 'outside' %} is-nav-prev-outside{% else %} is-nav-prev-inside{% endif %}"
                                aria-label="Previous slide"
                            >
                                {% sw_icon 'arrow-head-left' %}
                            </button>
                            <button
                                class="base-slider-controls-next image-slider-controls-next{% if navigationArrows == 'outside' %} is-nav-next-outside{% else %} is-nav-next-inside{% endif %}"
                                aria-label="Next slide"
                            >
                                {% sw_icon 'arrow-head-right' %}
                            </button>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
