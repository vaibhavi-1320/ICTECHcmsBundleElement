{% block element_ict_image_gallery %}
    {% set galleryTitle = element.data.galleryTitle ?? element.config.galleryTitle.value ?? '' %}
    {% set columns = element.data.columns ?? element.config.columns.value ?? 4 %}
    {% set galleryItems = element.data.galleryItems ?? [] %}

    {% if galleryItems|length > 0 %}
        <div class="cms-element-ict-image-gallery ict-image-gallery ict-image-gallery--columns-{{ columns }}" data-ict-gallery>
            {% if galleryTitle %}
                <h2 class="ict-image-gallery__title">
                    {{ galleryTitle }}
                </h2>
            {% endif %}

            <div class="ict-image-gallery__grid">
                {% for image in galleryItems %}
                    {% set media = image.media ?? null %}

                    {% if media %}
                        {% set caption = image.title|default(media.translated.alt|default(media.translated.title|default(''))) %}
                        {% set triggerLabel = caption|default(galleryTitle|default('Gallery image')) %}
                        {% set attributes = {
                            'class': 'ict-image-gallery__image',
                            'alt': media.translated.alt|default(caption),
                            'title': media.translated.title|default(caption),
                            'loading': 'lazy',
                            'decoding': 'async'
                        } %}

                        <button
                            type="button"
                            class="ict-image-gallery__item"
                            data-ict-gallery-item
                            data-ict-gallery-src="{{ media.url }}"
                            data-ict-gallery-alt="{{ media.translated.alt|default(caption)|e('html_attr') }}"
                            data-ict-gallery-caption="{{ caption|e('html_attr') }}"
                            aria-label="{{ triggerLabel|sw_sanitize }}"
                        >
                            <span class="ict-image-gallery__media">
                                {% sw_thumbnails 'ict-image-gallery-thumbnails' with {
                                    media: media,
                                    attributes: attributes
                                } %}
                            </span>

                            {% if caption %}
                                <span class="ict-image-gallery__caption">
                                    {{ caption }}
                                </span>
                            {% endif %}
                        </button>
                    {% endif %}
                {% endfor %}
            </div>

            <div
                class="ict-image-gallery__lightbox"
                data-ict-gallery-modal
                aria-hidden="true"
            >
                <div
                    class="ict-image-gallery__lightbox-backdrop"
                    data-ict-gallery-backdrop
                ></div>

                <div
                    class="ict-image-gallery__lightbox-dialog"
                    role="dialog"
                    aria-modal="true"
                    aria-label="{{ galleryTitle|default('Image gallery') }}"
                >
                    <button
                        type="button"
                        class="ict-image-gallery__lightbox-close"
                        data-ict-gallery-close
                        aria-label="{{ 'general.close'|trans|striptags }}"
                    >
                        {% sw_icon 'x' %}
                    </button>

                    <button
                        type="button"
                        class="ict-image-gallery__lightbox-nav is-prev"
                        data-ict-gallery-prev
                        aria-label="{{ 'general.previous'|trans|striptags }}"
                    >
                        {% sw_icon 'arrow-head-left' %}
                    </button>

                    <figure class="ict-image-gallery__lightbox-stage">
                        <img
                            data-ict-gallery-modal-image
                            src=""
                            alt=""
                            class="ict-image-gallery__lightbox-image"
                        >
                        <figcaption
                            class="ict-image-gallery__lightbox-caption"
                            data-ict-gallery-modal-caption
                        ></figcaption>
                    </figure>

                    <button
                        type="button"
                        class="ict-image-gallery__lightbox-nav is-next"
                        data-ict-gallery-next
                        aria-label="{{ 'general.next'|trans|striptags }}"
                    >
                        {% sw_icon 'arrow-head-right' %}
                    </button>

                    <div
                        class="ict-image-gallery__lightbox-counter"
                        data-ict-gallery-counter
                    ></div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
