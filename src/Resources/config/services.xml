<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <defaults autowire="true"
                  autoconfigure="true"
                  public="false"/>

        <!-- Column resolvers (extend ImageCmsElementResolver, no extra deps) -->
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctThreeColumnCmsElementResolver">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctTwoColumnCmsElementResolver">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctFiveColumnCmsElementResolver">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctSixColumnCmsElementResolver">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctNineColumnCmsElementResolver">
            <argument type="service" id="Shopware\Core\Content\Media\Cms\DefaultMediaResolver"/>
        </service>

        <!-- Gallery micro-classes -->
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\ExtractGalleryMediaIds"/>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\ResolveGalleryMedia"/>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\MapGalleryItem">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\ResolveGalleryMedia"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\BuildGalleryItem">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\MapGalleryItem"/>
        </service>

        <!-- Category micro-classes -->
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\MapCategoryCard">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\ResolveCategoryEntity"/>
        </service>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\BuildCategoryCard">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\MapCategoryCard"/>
        </service>

        <!-- Media micro-classes -->
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Media\BuildMediaCriteria"/>
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Media\ResolveMediaEntry"/>

        <!-- Resolvers -->
        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctImageGalleryCmsElementResolver">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\ExtractGalleryMediaIds"/>
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Gallery\BuildGalleryItem"/>
        </service>

        <service id="ICTECHcmsBundleElement\Core\Content\Cms\IctCategoryImageSliderCmsElementResolver">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\ExtractCategoryIds"/>
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Category\BuildCategoryCard"/>
        </service>

        <service id="ICTECHcmsBundleElement\Core\Content\Cms\DataResolver\Element\IctTwoColumnThreeImageElementDataResolver">
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Media\BuildMediaCriteria"/>
            <argument type="service" id="ICTECHcmsBundleElement\Core\Content\Cms\Helper\Media\ResolveMediaEntry"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>
    </services>
</container>
