{% block sw_cms_element_preview_ict_hero_section %}
<div class="sw-cms-el-preview-ict-hero-section">
    <div class="sw-cms-el-preview-ict-hero-section__container">
        <!-- Left Section Preview -->
        <div class="sw-cms-el-preview-ict-hero-section__left-section">
            <div class="sw-cms-el-preview-ict-hero-section__label">
                Large Format Displays
            </div>
            <h1 class="sw-cms-el-preview-ict-hero-section__headline">
                Stunning Video Wall Systems<br>for Maximum Impact
            </h1>
            <p class="sw-cms-el-preview-ict-hero-section__description">
                Professional video wall solutions for control rooms, retail, and immersive environments
            </p>
            <div class="sw-cms-el-preview-ict-hero-section__buttons">
                <div class="sw-cms-el-preview-ict-hero-section__button sw-cms-el-preview-ict-hero-section__button--primary">
                    Design Your Video Wall →
                </div>
                <div class="sw-cms-el-preview-ict-hero-section__button sw-cms-el-preview-ict-hero-section__button--secondary">
                    Learn More
                </div>
            </div>
        </div>

        <!-- Right Section Preview -->
        <div class="sw-cms-el-preview-ict-hero-section__right-section">
            <div class="sw-cms-el-preview-ict-hero-section__feature-grid">
                <div class="sw-cms-el-preview-ict-hero-section__feature-item">
                    <div class="sw-cms-el-preview-ict-hero-section__feature-icon">⊞</div>
                    <div class="sw-cms-el-preview-ict-hero-section__feature-content">
                        <h3>Modular Design</h3>
                        <p>Scalable configurations</p>
                    </div>
                </div>
                <div class="sw-cms-el-preview-ict-hero-section__feature-item">
                    <div class="sw-cms-el-preview-ict-hero-section__feature-icon">▢</div>
                    <div class="sw-cms-el-preview-ict-hero-section__feature-content">
                        <h3>Ultra-Thin Bezels</h3>
                        <p>Seamless viewing</p>
                    </div>
                </div>
                <div class="sw-cms-el-preview-ict-hero-section__feature-item">
                    <div class="sw-cms-el-preview-ict-hero-section__feature-icon">⤢</div>
                    <div class="sw-cms-el-preview-ict-hero-section__feature-content">
                        <h3>Any Size</h3>
                        <p>Custom dimensions</p>
                    </div>
                </div>
                <div class="sw-cms-el-preview-ict-hero-section__feature-item">
                    <div class="sw-cms-el-preview-ict-hero-section__feature-icon">⚡</div>
                    <div class="sw-cms-el-preview-ict-hero-section__feature-content">
                        <h3>24/7 Operation</h3>
                        <p>Commercial grade</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}