                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonLink')"
                                @update:model-value="onRightTopButtonLink">
                        </mt-text-field>
                    </div>

                    <div class="sw-cms-el-config-ict-three-column-image-box_button_styling">
                        <div class="button-color-config">
                            <mt-colorpicker
                                    v-model="element.config.rightTopButtonBackgroundColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonBackgroundColor')"
                                    @update:model-value="onRightTopButtonBackgroundColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.rightTopButtonHoverBackgroundColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonHoverBackgroundColor')"
                                    @update:model-value="onRightTopButtonHoverBackgroundColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.rightTopButtonTextColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonTextColor')"
                                    @update:model-value="onRightTopButtonTextColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.rightTopButtonHoverTextColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonHoverTextColor')"
                                    @update:model-value="onRightTopButtonHoverTextColorChange">
                            </mt-colorpicker>
                        </div>

                        <div class="button-border-config">
                            <mt-colorpicker
                                    v-model="element.config.rightTopButtonBorderColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonBorderColor')"
                                    @update:model-value="onRightTopButtonBorderColorChange">
                            </mt-colorpicker>
                        </div>
                    </div>
                </div>
            </sw-container>

            <!-- Right Bottom Image -->
            <sw-container v-if="active === 'rightBottomImage' && element.config"
                          class="sw-cms-el-config-ict-two-column-right-bottom-image-section__main"
                          :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.rightBottomImage')">
                <!-- Right Bottom Image Configuration -->
                <sw-upload-listener
                        :upload-tag="rightBottomImageUploadTag"
                        @media-upload-finish="onRightBottomImageUpload"
                        auto-upload>
                </sw-upload-listener>

                <sw-media-upload-v2
