                        @media-upload-sidebar-open="onOpenRightTopImageModal">
                </sw-media-upload-v2>

                <sw-media-modal-v2
                        v-if="rightTopImageMediaModalIsOpen"
                        :initial-folder-id="null"
                        :entity-context="'cms_page'"
                        @media-modal-selection-change="onRightTopImageSelectionChanges"
                        @modal-close="onCloseRightTopImageModal">
                </sw-media-modal-v2>

                <div class="sw-cms-el-config-ict-three-column-image-box_config_mode">
                    <mt-select
                            v-model="element.config.rightTopImageObjectFit.value"
                            :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightImageObjectFit')"
                            :options="objectFitOptions"
                            @update:model-value="onRightTopImageObjectFit">
                    </mt-select>

                
                     <mt-text-field
                         v-if="element.config.rightTopImageObjectFit.value === 'cover' "
                         v-model="element.config.rightTopImageHeight.value"
                         :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightImageHeight')"
                         @update:model-value="onRightTopImageHeight">
                     </mt-text-field>
                </div>

                <div class="sw-cms-el-config-ict-three-column-image-box_text_config">
                    <sw-text-editor
