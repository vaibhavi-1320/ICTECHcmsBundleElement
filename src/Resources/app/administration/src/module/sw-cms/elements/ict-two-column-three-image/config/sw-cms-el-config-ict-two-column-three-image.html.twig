                        :source="rightBottomImageMediaItem"
                        :allow-multi-select="false"
                        :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightBottomImage')"
                        :default-folder="'cms_page'"
                        :file-accept="fileAccept"
                        @selection-change="onRightBottomImageSelectionChanges"
                        @media-upload-remove-image="onRightBottomImageRemove"
                        @media-upload-sidebar-open="onOpenRightBottomImageModal">
                </sw-media-upload-v2>

                <sw-media-modal-v2
