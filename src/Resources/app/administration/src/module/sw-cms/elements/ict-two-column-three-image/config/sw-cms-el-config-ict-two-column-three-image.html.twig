{% block sw_cms_el_config_ict_product_box %}
    <sw-tabs class="sw-cms-el-config-ict-three-column-image-box" default-item="leftImage">

        <template #default="{ active }">
            <sw-tabs-item name="leftImage" :active-tab="active">
                {{ $tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.leftImage') }}
            </sw-tabs-item>
            <sw-tabs-item name="rightTopImage" :active-tab="active">
                {{ $tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.rightTopImage') }}
            </sw-tabs-item>
            <sw-tabs-item name="rightBottomImage" :active-tab="active">
                {{ $tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.rightBottomImage') }}
            </sw-tabs-item>
        </template>
        <template #content="{ active }">
            <!-- Left Image -->
            <sw-container v-if="active === 'leftImage' && element.config" class="sw-cms-el-config-ict-three-column-left-image-section__main"
                          :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.leftImage')">
                <!-- Left Image Configuration -->
                <sw-upload-listener
                        :upload-tag="leftImageUploadTag"
                        @media-upload-finish="onLeftImageUpload"
                        auto-upload>
                </sw-upload-listener>

                <sw-media-upload-v2
                        variant="regular"
                        :upload-tag="leftImageUploadTag"
                        :source="leftImageMediaItem"
                        :allow-multi-select="false"
                        :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftImage')"
                        :default-folder="'cms_page'"
                        :file-accept="fileAccept"
                        @selection-change="onLeftImageSelectionChanges"
                        @media-upload-remove-image="onLeftImageRemove"
                        @media-upload-sidebar-open="onOpenLeftImageModal">
                </sw-media-upload-v2>

                <sw-media-modal-v2
                        v-if="leftImageMediaModalIsOpen"
                        :initial-folder-id="null"
                        :entity-context="'cms_page'"
                        @media-modal-selection-change="onLeftImageSelectionChanges"
                        @modal-close="onCloseLeftImageModal">
                </sw-media-modal-v2>

                <div class="sw-cms-el-config-ict-three-column-image-box_config_mode">
                    <mt-select
                            v-model="element.config.leftImageObjectFit.value"
                            :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftImageObjectFit')"
                            :options="objectFitOptions"
                            @update:model-value="onLeftImageObjectFit">
                    </mt-select>

                     <mt-text-field
                               v-if="element.config.leftImageObjectFit.value === 'cover' "
                                v-model="element.config.leftImageHeight.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftImageHeight')"
                                @update:model-value="onLeftImageHeight">
                     </mt-text-field>

                </div>

                <div class="sw-cms-el-config-ict-three-column-image-box_text_config">
                    <sw-text-editor
                            :value="element.config.leftImageDescription.value"
                            :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftImageDescription')"
                            sanitize-input
                            @update:value="onLeftImageDescriptionInput">
                    </sw-text-editor>
                </div>

                <div class="sw-cms-el-config-ict-three-column-image-box_button">
                    <div class="sw-cms-el-config-ict-three-column-image-box_button_icon">
                        <sw-upload-listener
                                :upload-tag="leftButtonIconUploadTag"
                                @media-upload-finish="onLeftButtonIconUpload"
                                auto-upload>
                        </sw-upload-listener>

                        <sw-media-upload-v2
                                variant="regular"
                                :upload-tag="leftButtonIconUploadTag"
                                :source="leftButtonIconMediaItem"
                                :allow-multi-select="false"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftButtonIcon')"
                                :default-folder="'cms_page'"
                                :file-accept="buttonImageAccept"
                                        @selection-change="onLeftButtonIconSelectionChanges"
                                @media-upload-remove-image="onLeftButtonIconRemove"
                                @media-upload-sidebar-open="onOpenLeftButtonIconModal">
                        </sw-media-upload-v2>

                        <sw-media-modal-v2
                                v-if="leftButtonIconMediaModalIsOpen"
                                :initial-folder-id="null"
                                :entity-context="'cms_page'"
                                @media-modal-selection-change="onLeftButtonIconSelectionChanges"
                                @modal-close="onCloseLeftButtonIconModal">
                        </sw-media-modal-v2>
                    </div>

                    <div class="sw-cms-el-config-ict-three-column-image-box_button_config">
                        <mt-select
                                v-model="element.config.leftButtonIconSize.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftButtonIconSize')"
                                :options="buttonIconSizeOptions"
                                @update:model-value="onLeftButtonIconSizeChange">
                        </mt-select>
                        <mt-switch
                                v-model="element.config.leftButtonIconHoverActive.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftButtonIconHoverActive')"
                                @update:model-value="onLeftButtonIconHoverActiveChange">
                        </mt-switch>
                        <mt-colorpicker
                                v-if="element.config.leftButtonIconHoverActive.value"
                                v-model="element.config.leftButtonIconHoverColor.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftButtonIconHoverColor')"
                                @update:model-value="onLeftButtonIconHoverColorChange">
                        </mt-colorpicker>
                        <mt-text-field
                                v-model="element.config.leftButtonTitle.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.leftButtonText')"
                                @update:model-value="onLeftButtonTitleInput">
                        </mt-text-field>

                        <mt-select
                                v-model="element.config.leftButtonLinkType.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonLinkType')"
                                :options="linkTypeOptions"
                                @update:model-value="onLeftButtonLinkType">
                        </mt-select>
                    </div>
                    <div class="sw-cms-el-config-ict-three-column-image-box-url-field">
                        <sw-dynamic-url-field
                                v-if="element.config.leftButtonLinkType && element.config.leftButtonLinkType.value === 'internal'"
                                v-model:value="element.config.leftButtonLink.value"></sw-dynamic-url-field>
                    </div>
                    <div>
                        <mt-text-field
                                v-if="element.config.leftButtonLinkType.value === 'external'"
                                v-model="element.config.leftButtonLink.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonLink')"
                                @update:model-value="onLeftButtonLink">
                        </mt-text-field>
                    </div>

                    <div class="sw-cms-el-config-ict-three-column-image-box_button_styling">
                        <div class="button-color-config">
                            <mt-colorpicker
                                    v-model="element.config.leftButtonBackgroundColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonBackgroundColor')"
                                    @update:model-value="onLeftButtonBackgroundColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.leftButtonHoverBackgroundColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonHoverBackgroundColor')"
                                    @update:model-value="onLeftButtonHoverBackgroundColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.leftButtonTextColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonTextColor')"
                                    @update:model-value="onLeftButtonTextColorChange">
                            </mt-colorpicker>

                            <mt-colorpicker
                                    v-model="element.config.leftButtonHoverTextColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonHoverTextColor')"
                                    @update:model-value="onLeftButtonHoverTextColorChange">
                            </mt-colorpicker>
                        </div>

                        <div class="button-border-config">
                            <mt-colorpicker
                                    v-model="element.config.leftButtonBorderColor.value"
                                    :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.buttonBorderColor')"
                                    @update:model-value="onLeftButtonBorderColorChange">
                            </mt-colorpicker>
                        </div>
                    </div>
                </div>
            </sw-container>
            
            <!-- Right Image -->
            <sw-container v-if="active === 'rightTopImage' && element.config"
                          class="sw-cms-el-config-ict-two-column-right-top-image-section__main"
                          :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.tab.rightTopImage')">
