                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightTopButtonIconHoverActive')"
                                @update:model-value="onRightTopButtonIconHoverActiveChange">
                        </mt-switch>
                        <mt-colorpicker
                                v-if="element.config.rightTopButtonIconHoverActive.value"
                                v-model="element.config.rightTopButtonIconHoverColor.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightTopButtonIconHoverColor')"
                                @update:model-value="onRightTopButtonIconHoverColorChange">
                        </mt-colorpicker>
                        <mt-text-field
                                v-model="element.config.rightTopButtonTitle.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightButtonText')"
                                @update:model-value="onRightTopButtonTitleInput">
