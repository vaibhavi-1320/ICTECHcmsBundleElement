                                v-if="rightBottomButtonIconMediaModalIsOpen"
                                :initial-folder-id="null"
                                :entity-context="'cms_page'"
                                @media-modal-selection-change="onRightBottomButtonIconSelectionChanges"
                                @modal-close="onCloseRightBottomButtonIconModal">
                        </sw-media-modal-v2>
                    </div>

                    <div class="sw-cms-el-config-ict-three-column-image-box_button_config">
                        <mt-select
                                v-model="element.config.rightBottomButtonIconSize.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightBottomButtonIconSize')"
                                :options="buttonIconSizeOptions"
                                @update:model-value="onRightBottomButtonIconSizeChange">
                        </mt-select>
                        <mt-switch
                                v-model="element.config.rightBottomButtonIconHoverActive.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightBottomButtonIconHoverActive')"
                                @update:model-value="onRightBottomButtonIconHoverActiveChange">
                        </mt-switch>
                        <mt-colorpicker
                                v-if="element.config.rightBottomButtonIconHoverActive.value"
                                v-model="element.config.rightBottomButtonIconHoverColor.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightBottomButtonIconHoverColor')"
                                @update:model-value="onRightBottomButtonIconHoverColorChange">
                        </mt-colorpicker>
                        <mt-text-field
                                v-model="element.config.rightBottomButtonTitle.value"
                                :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightButtonText')"
                                @update:model-value="onRightBottomButtonTitleInput">
