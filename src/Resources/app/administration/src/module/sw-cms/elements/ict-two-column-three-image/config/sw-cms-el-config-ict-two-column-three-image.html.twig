                        :initial-folder-id="null"
                        :entity-context="'cms_page'"
                        @media-modal-selection-change="onRightBottomImageSelectionChanges"
                        @modal-close="onCloseRightBottomImageModal">
                </sw-media-modal-v2>

                <div class="sw-cms-el-config-ict-three-column-image-box_config_mode">
                    <mt-select
                            v-model="element.config.rightBottomImageObjectFit.value"
                            :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightImageObjectFit')"
                            :options="objectFitOptions"
                            @update:model-value="onRightBottomObjectFit">
                    </mt-select>

                   <mt-text-field
                          v-if="element.config.rightBottomImageObjectFit.value === 'cover' "
                            v-model="element.config.rightBottomImageHeight.value"
                            :label="$tc('sw-cms.elements.ictTwoColumnThreeImage.config.label.rightImageHeight')"
                         @update:model-value="onRightBottomHeight">
